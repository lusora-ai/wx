{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"vite --port=3100 --host=0.0.0.0\" \"tsx watch server/index.ts\"",
    "client:dev": "vite --port=3100 --host=0.0.0.0",
    "server:dev": "tsx watch server/index.ts",
    "build": "vite build && tsc --noEmit",
    "preview": "vite preview",
    "clean": "rm -rf dist server.js",
    "lint": "tsc --noEmit",
    "test:e2e": "tsx scripts/e2e-main-flow.ts",
    "db:push": "tsx prisma/push.ts",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "ai:smoke": "tsx scripts/ai-health-smoke.ts",
    "wechat:html:test": "tsx scripts/wechat-html-adapter-check.ts",
    "db:clear-demo": "tsx scripts/clear-demo-data.ts --execute",
    "db:clear-demo:dry": "tsx scripts/clear-demo-data.ts --dry-run"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.10.0",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "marked": "^18.0.4",
    "motion": "^12.23.24",
    "playwright": "^1.49.1",
    "prisma": "^7.8.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "vite": "^6.2.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
