DATABASE_URL="file:./dev.db"

# Active server-side text models. Product features only use DeepSeek v4 Pro and Kimi 2.6.
LLM_PROVIDER="kimi"

# DeepSeek, server-side only.
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
DEEPSEEK_MODEL="deepseek-v4-pro"

# Kimi / Moonshot, server-side only.
KIMI_API_KEY=""
KIMI_BASE_URL="https://api.moonshot.cn/v1"
KIMI_MODEL="kimi-k2.6"

APP_URL="http://localhost:3100"
API_PORT="8787"
LLM_TIMEOUT_MS="90000"
KIMI_TIMEOUT_MS="90000"

# WeChat automation PoC. Disabled by default; session files must never be committed.
# Set to "true" to enable Playwright-based WeChat PoC. Restart backend after changing.
WECHAT_AUTOMATION_ENABLED="false"
WECHAT_SESSION_PATH=".local/wechat-session.json"
WECHAT_HEADLESS="false"
WECHAT_OPERATION_DELAY_MIN_MS="1000"
WECHAT_OPERATION_DELAY_MAX_MS="3000"
WECHAT_LOGIN_TIMEOUT_MS="120000"
WECHAT_PAGE_TIMEOUT_MS="45000"
WECHAT_KEEP_BROWSER_OPEN_AFTER_INJECT="true"
WECHAT_KEEP_BROWSER_OPEN_AFTER_SAVE="true"
WECHAT_BROWSER_KEEP_ALIVE_MS="600000"
